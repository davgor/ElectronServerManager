{
  "appId": "com.electronservermanager.app",
  "productName": "Game Server Manager",
  "artifactName": "Game-Server-Manager-${version}.${ext}",
  "files": [
    "dist/main/**/*",
    "dist/preload/**/*",
    "dist/renderer/**/*",
    "dist/types/**/*",
    "node_modules/**/*"
  ],
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "davgor",
      "repo": "ElectronServerManager"
    }
  ],
  "win": {
    "icon": "assets/icon.png",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "artifactName": "Game-Server-Manager-Setup-${version}.${ext}"
  },
  "portable": {
    "artifactName": "Game-Server-Manager-Portable-${version}.${ext}"
  },
  "mac": {
    "target": ["dmg", "zip"]
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "artifactName": "Game-Server-Manager-${version}.${ext}"
  }
}
